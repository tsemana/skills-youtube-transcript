# @defaultSensitive=true @defaultRequired=infer

# 1Password Service Account token (scoped to AI vault only, read-only)
# Retrieved from macOS Keychain — no auth prompt needed
# @type=string @required @sensitive
OP_SERVICE_ACCOUNT_TOKEN=exec(`security find-generic-password -a tonysemana -s op-agent-skills-token -w`)

# Gemini API key fetched from 1Password AI vault via service account
# @type=string @required @sensitive
GEMINI_API_KEY=exec(`OP_SERVICE_ACCOUNT_TOKEN=$(security find-generic-password -a tonysemana -s op-agent-skills-token -w) op read "op://AI/gemini-api-key-transcript/password"`)

# Gemini model to use for transcription
# @type=string @sensitive=false
GEMINI_MODEL=gemini-2.5-flash

# Directory where transcripts are saved by default
# @type=string @sensitive=false
TRANSCRIPT_OUTPUT_DIR=~/CascadeProjects/semantechs/transcripts
